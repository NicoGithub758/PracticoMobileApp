<?xml version="1.0" encoding="utf-8" ?>
<Shell xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
       xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
       xmlns:local="clr-namespace:PracticoMobileApp"
       x:Class="PracticoMobileApp.AppShell">

    <!-- Pantalla de selección de sitios (primera pantalla) -->
    <ShellContent Title="Sitios"
                  ContentTemplate="{DataTemplate local:SitiosPage}"
                  Route="SitiosPage"
                  Shell.NavBarIsVisible="False"/>

    <!-- Pantalla principal -->
    <ShellContent Title="Inicio"
                  ContentTemplate="{DataTemplate local:MainPage}"
                  Route="MainPage"/>

</Shell>

